# Copy this file to .env.atlas.prod and fill in the real Neon PRODUCTION URL.
# .env.atlas.* is gitignored (matched by .env.* in .gitignore), so the real
# file is never committed and the URL never appears in your shell history.
#
#   cp .env.atlas.prod.example .env.atlas.prod
#   # then edit the value below
#
# Use the DIRECT (non-pooled) Neon connection string for DDL/migrations.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/DBNAME?sslmode=require
