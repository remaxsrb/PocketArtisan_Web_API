# ----------------------------------------------------------------------
# Go build artifacts & caches
# ----------------------------------------------------------------------
/bin/
/obj/
/out/
*.exe
*.dll
*.so
*.dylib
*.test
*.out
*.patch
/uploads/
/notes/

# Compiled object files
*.o
*.a

# Go workspace cache (if you ever commit $GOPATH)
pkg/
vendor/

# ----------------------------------------------------------------------
# IDE / editor specific files
# ----------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# JetBrains (GoLand, IntelliJ, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
.session
*~

# Emacs
*~
\#*\#
.#*

# ----------------------------------------------------------------------
# OS generated files
# ----------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
Icon?
._*

# ----------------------------------------------------------------------
# Dependency / module files (usually you *do* commit go.mod & go.sum)
# ----------------------------------------------------------------------
# go.mod and go.sum are **important** – keep them tracked!
# If you ever generate vendored copies, ignore the vendor folder:
# /vendor/

# ----------------------------------------------------------------------
# Secrets & configuration files (do NOT commit!)
# ----------------------------------------------------------------------
# .dot files used for local secrets (e.g., pg_dsn.dot, jwt_private_key.dot)
*.dot

# Any other config files that contain credentials
.env
.env.*
# ...but keep the committed example templates for Atlas migration env files:
!.env.atlas.dev.example
!.env.atlas.prod.example
config.yaml
config.yml
secrets/
*.pem
*.key
*.crt

# ----------------------------------------------------------------------
# Test / coverage reports
# ----------------------------------------------------------------------
coverage.out
*.coverprofile
*.prof

# ----------------------------------------------------------------------
# Generated files (protobuf, swagger, etc.)
# ----------------------------------------------------------------------
*.gen.go
*.pb.go
*.swagger.json
*.swagger.yaml

# ----------------------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------------------
# Logs
*.log

# Temporary files
tmp/
temp/
*.tmp

# Docker / Kubernetes
docker-compose.override.yml
.kube/
.kubeconfig

# ----------------------------------------------------------------------
# Database migrations (Atlas)
# ----------------------------------------------------------------------
# The versioned migrations and their checksum ARE the source of truth — keep
# them tracked:
#   !migrations/            (SQL files applied to every environment)
#   !migrations/atlas.sum   (integrity checksum; CI fails if it drifts)
#   !atlas.hcl              (Atlas project config)
#
# Ignore only local, machine-specific Atlas artifacts:
# optional local env overrides
atlas.hcl.local
# local Atlas CLI state/cache
.atlas/
# atlas binary if downloaded into the repo root
/atlas
# compiled cmd/atlasloader binary (build artifact)
/atlasloader

# End of .gitignore